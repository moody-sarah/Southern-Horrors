              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "A note on language",
                  "textSize": "heading-four"
                },
                {
                  "text": " "
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "This project presents the period writing without modernization, meaning some terms may cause offense. When appropriate an annotation explains the meaning of terms that might not be understood."
                }
              ]
            }
