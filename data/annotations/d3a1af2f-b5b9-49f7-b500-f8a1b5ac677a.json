{"annotations":[{"start_time":0,"end_time":28,"annotation":[{"type":"paragraph","children":[{"text":"metarecording"}]}],"tags":[{"tag":"metarecording","category":"metarecording"}],"uuid":"058db191-6292-4cb0-899e-60303a3996d6"},{"start_time":29,"end_time":105,"annotation":[{"type":"paragraph","children":[{"text":"a white woman in Ohio makes a false accusation, leading to trial and conviction of a Black man; she later confessed to her lie, after the falsely convicted had served four years; her husband secured his release and divorced the wife"}]}],"tags":[{"tag":"false accusation of rape","category":"law enforcement and courts"},{"tag":"conviction","category":"law enforcement and courts"}],"uuid":"fdf74cc7-b6af-4988-a753-8459d9965784"},{"start_time":106,"end_time":201,"annotation":[{"type":"paragraph","children":[{"text":"The accuser confesses that the relationship was consensual; the falsely convicted is freed, and the woman and husband divorce."}]}],"tags":[{"tag":"consensual interracial relationship","category":"human relationships"},{"tag":"child","category":"human relationships"},{"tag":"divorce","category":"human relationships"}],"uuid":"6497176b-7ee8-4103-964a-a027e11ab7ba"},{"start_time":164,"end_time":173,"annotation":[{"type":"paragraph","children":[{"text":"\"outrage\" as \"rape\" (a period usage)"}]}],"tags":[{"category":"language issues","tag":"language use"}],"uuid":"d8da69bd-7672-4259-9258-bf7e998fc941"},{"start_time":215,"end_time":228,"annotation":[{"type":"paragraph","children":[{"text":"Wells contrasts Northern with Southern cases of interracial sexual relationships"}]}],"tags":[{"tag":"consensual interracial relationship","category":"human relationships"}],"uuid":"54b19e5d-2cb5-475e-95f4-3284d922d618"},{"start_time":229,"end_time":255,"annotation":[{"type":"paragraph","children":[{"text":"a white Memphis woman runs away with her Black coachman"}]}],"tags":[{"tag":"consensual interracial relationship","category":"human relationships"},{"tag":"Memphis","category":"recurring places"}],"uuid":"c8e0069b-11c7-4195-8592-9c2fb7901348"},{"start_time":256,"end_time":278,"annotation":[{"type":"paragraph","children":[{"text":"a white girl's accusation leads to acquittal in Memphis"}]}],"tags":[{"tag":"false accusation of rape","category":"law enforcement and courts"},{"tag":"acquittal","category":"law enforcement and courts"},{"tag":"Memphis","category":"recurring places"}],"uuid":"009feca9-eef0-4d0d-8472-df5cedf44894"},{"start_time":279,"end_time":308,"annotation":[{"type":"paragraph","children":[{"text":"a white Memphis woman asserts she is Black to continue cohabiting with a Black man"}]}],"tags":[{"tag":"indictment","category":"law enforcement and courts"},{"tag":"acquittal","category":"law enforcement and courts"},{"tag":"consensual interracial relationship","category":"human relationships"},{"tag":"class","category":"class"},{"tag":"Memphis","category":"recurring places"}],"uuid":"06fc8fb7-4ec9-4ceb-a415-3d893f49311d"},{"start_time":309,"end_time":331,"annotation":[{"type":"paragraph","children":[{"text":"a white Memphis woman stole and moved for her Black lover"}]}],"tags":[{"tag":"consensual interracial relationship","category":"human relationships"}],"uuid":"4c04ce2c-8d3a-44e6-b35c-184a57e64716"},{"start_time":332,"end_time":437,"annotation":[{"type":"paragraph","children":[{"text":"quotation from The Memphis Ledger on the Lillie Bailey story. \"Coon\" is a racial slur that likely abbreviates \"raccoon.\""}]}],"tags":[{"tag":"consensual interracial relationship","category":"human relationships"},{"tag":"child","category":"human relationships"},{"category":"language issues","tag":"language explanation"},{"tag":"Memphis","category":"recurring places"}],"uuid":"68413ef4-7d4a-4eff-a5e9-4f5c74d96d59"},{"start_time":438,"end_time":464,"annotation":[{"type":"paragraph","children":[{"text":"Wells analyzes the language used in the quotation to, among other things, highlight a case of institutional segregation."}]}],"tags":[{"tag":"analysis","category":"analysis"}],"uuid":"760b7bc3-9373-460c-88d1-fb1d81c41663"},{"start_time":465,"end_time":499,"annotation":[{"type":"paragraph","children":[{"text":"A white woman makes an excuse for why a Black man was in her room at night, saving him from lynching. "}]}],"tags":[{"tag":"consensual interracial relationship","category":"human relationships"},{"tag":"Memphis","category":"recurring places"}],"uuid":"88fc25fd-0cc8-474b-bd55-617a4c403da3"},{"start_time":500,"end_time":553,"annotation":[{"type":"paragraph","children":[{"text":"Additional cases elsewhere in the South of white women or girls with Black lovers or mixed-race babies."}]}],"tags":[{"tag":"consensual interracial relationship","category":"human relationships"}],"uuid":"89f2768d-55bf-4718-a988-34ff463851d1"},{"start_time":554,"end_time":601,"annotation":[{"type":"paragraph","children":[{"text":"Lynching of Edward Coy in Texarcana, with list of evidence disproving the accusations against him."}]}],"tags":[{"category":"law enforcement and courts","tag":"lynching"},{"tag":"consensual interracial relationship","category":"human relationships"}],"uuid":"1e014a80-c6f0-4c3d-b419-8447eb6e5caf"},{"start_time":602,"end_time":610,"annotation":[{"type":"paragraph","children":[{"text":"white men involved in a lynching are themselves fathers of mixed-race children"}]}],"tags":[{"tag":"child","category":"human relationships"}],"uuid":"e0acdf55-459d-4c4f-bbc6-112d47e91d1a"},{"start_time":611,"end_time":650,"annotation":[{"type":"paragraph","children":[{"text":"the Chicago Inter Ocean calls for an inquiry into how to \"excuse injustice\"; they also propose that the white woman was \"more guilty\" than the Black man for their relationship"}]}],"tags":[{"tag":"analysis","category":"analysis"},{"tag":"white impunity","category":"law enforcement and courts"}],"uuid":"ca93cfb8-071b-4579-9e8a-e23a5d976549"},{"start_time":651,"end_time":720,"annotation":[{"type":"paragraph","children":[{"text":"a white woman in Natchez gives birth to two mixed-race children, fathered by her coachman. Two families are ruined."}]}],"tags":[{"tag":"consensual interracial relationship","category":"human relationships"},{"tag":"child","category":"human relationships"}],"uuid":"7b710757-27f5-4140-a7f5-44f17de0d3c9"},{"start_time":721,"end_time":745,"annotation":[{"type":"paragraph","children":[{"text":"A man of color in Issaquena County is lynched for writing a note to a white woman"}]}],"tags":[{"category":"law enforcement and courts","tag":"lynching"}],"uuid":"0985d8d4-0087-4bbc-a350-9fa909ba79cb"},{"start_time":746,"end_time":796,"annotation":[{"type":"paragraph","children":[{"text":"Wells argues that cases like these are frequent and well-known in the South, and interracial love is not rare."}]}],"tags":[{"tag":"analysis","category":"analysis"},{"tag":"class","category":"class"},{"category":"law enforcement and courts","tag":"law enforcement and courts"}],"uuid":"f9b463ee-4dc9-4ff2-85a8-809c1ad7eeff"},{"start_time":797,"end_time":825,"annotation":[{"type":"paragraph","children":[{"text":"Bishop Fitzgerald and Governor Tillman punish only victimizers of (or those accused of victimizing) white women"}]}],"tags":[{"category":"law enforcement and courts","tag":"lynching"}],"uuid":"b3ab94ef-8e64-40d0-b4e7-61d099dd6d42"},{"start_time":826,"end_time":855,"annotation":[{"type":"paragraph","children":[{"text":"Baltimore, rape of a Black girl by white men. \"Outrage\" means rape (a period usage)."}]}],"tags":[{"tag":"Black female as victim","category":"human relationships"},{"tag":"acquittal","category":"law enforcement and courts"},{"category":"language issues","tag":"language use"}],"uuid":"722fb1c6-0a34-43de-8efd-97919da7d800"},{"start_time":856,"end_time":905,"annotation":[{"type":"paragraph","children":[{"text":"Two rape cases Black girls by white men; the men were protected or received disproportionately low sentences. \"Outrage\" means rape (a period usage)."}]}],"tags":[{"tag":"Black female as victim","category":"human relationships"},{"category":"law enforcement and courts","tag":"mob"},{"tag":"Nashville","category":"recurring places"},{"category":"language issues","tag":"language use"}],"uuid":"f5c3b115-da62-4216-9e54-26a9409b9d97"},{"start_time":906,"end_time":945,"annotation":[{"type":"paragraph","children":[{"text":"A Black man charged with rape of a white woman was attacked by a mob.  "}]}],"tags":[{"category":"law enforcement and courts","tag":"mob"},{"category":"law enforcement and courts","tag":"law enforcement"},{"tag":"Nashville","category":"recurring places"}],"uuid":"b75f0674-d81d-4bb0-a21e-d002111635d2"},{"start_time":946,"end_time":981,"annotation":[{"type":"paragraph","children":[{"text":"White man rapes a Black girl and is not harmed."}]}],"tags":[{"tag":"Black female as victim","category":"human relationships"},{"tag":"white impunity","category":"law enforcement and courts"},{"tag":"Nashville","category":"recurring places"},{"tag":"analysis","category":"analysis"}],"uuid":"3ce56feb-8913-425a-aa06-b2b6a2d8048a"},{"start_time":982,"end_time":1000,"annotation":[{"type":"paragraph","children":[{"text":"In Guthrie, a White man rapes and kills a Black girl and is not punished, while a Black man visiting a white woman is almost lynched."}]}],"tags":[{"tag":"white impunity","category":"law enforcement and courts"},{"category":"law enforcement and courts","tag":"lynching"},{"tag":"white impunity","category":"law enforcement and courts"}],"uuid":"bec4c6e4-26fd-4b03-be60-9e789cf0f5bc"},{"start_time":1001,"end_time":1027,"annotation":[{"type":"paragraph","children":[{"text":"A white man attempts to rape a Black woman"}]}],"tags":[{"tag":"white impunity","category":"law enforcement and courts"},{"tag":"Memphis","category":"recurring places"}],"uuid":"6676c99a-cc93-4d97-bf1b-dfe7f83924f7"},{"start_time":1026,"end_time":1044,"annotation":[{"type":"paragraph","children":[{"text":"metarecording"}]}],"tags":[{"tag":"metarecording","category":"metarecording"}],"uuid":"aa693d95-4a77-42d6-9b3f-e3769b3baa82"}],"set":"Default","event_id":"d8db8e82-dd54-4a15-b549-a943ad9a75b9","source_id":"81dea0a9-9497-445f-9ef4-51cb5ffc3631"}